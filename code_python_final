def apply_clahe(frame):
    lab = cv2.cvtColor(frame, cv2.COLOR_BGR2LAB)
    l, a, b = cv2.split(lab)
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))
    l = clahe.apply(l)
    return cv2.cvtColor(cv2.merge([l, a, b]), cv2.COLOR_LAB2BGR)


def _dist(p1, p2):
    return math.sqrt((p1[0]-p2[0])**2 + (p1[1]-p2[1])**2)


def compute_ear(lm, idx, w, h):
    pts = [(lm[i].x * w, lm[i].y * h) for i in idx]
    v1  = _dist(pts[1], pts[5])
    v2  = _dist(pts[2], pts[4])
    hz  = _dist(pts[0], pts[3])
    return (v1 + v2) / (2.0 * hz) if hz > 1e-6 else 0.0


def compute_mar(lm, w, h):
    ul = (lm[UPPER_LIP].x * w, lm[UPPER_LIP].y * h)
    ll = (lm[LOWER_LIP].x * w, lm[LOWER_LIP].y * h)
    ml = (lm[LEFT_MOUTH].x * w, lm[LEFT_MOUTH].y * h)
    mr = (lm[RIGHT_MOUTH].x * w, lm[RIGHT_MOUTH].y * h)
    hz = _dist(ml, mr)
    return _dist(ul, ll) / hz if hz > 1e-6 else 0.0


_cached_bbox    = None
_yolo_frame_cnt = 0


def detect_and_extract(frame, img_w, img_h):
    global _cached_bbox, _yolo_frame_cnt

    frame_c = apply_clahe(frame)
    _yolo_frame_cnt += 1

    # YOLO hanya jalan setiap YOLO_INTERVAL frame, sisanya pakai cache
    if _yolo_frame_cnt % YOLO_INTERVAL == 1 or _cached_bbox is None:
        res   = yolo_model(frame_c, verbose=False)
        boxes = res[0].boxes
        if len(boxes) > 0:
            confs    = boxes.conf.cpu().numpy()
            best_idx = int(np.argmax(confs))
            b        = boxes[best_idx].xyxy[0].cpu().numpy().astype(int)
            _cached_bbox = (
                max(0,     b[0] - CROP_PADDING),
                max(0,     b[1] - CROP_PADDING),
                min(img_w, b[2] + CROP_PADDING),
                min(img_h, b[3] + CROP_PADDING),
            )
        else:
            _cached_bbox = None

    if _cached_bbox is None:
        return False, None, None, None, None, None

    x1, y1, x2, y2 = _cached_bbox
    crop = frame_c[y1:y2, x1:x2]
    if crop.size == 0:
        _cached_bbox = None
        return False, None, None, None, None, None

    ch, cw   = crop.shape[:2]
    rgb_crop = cv2.cvtColor(crop, cv2.COLOR_BGR2RGB)
    lm       = face_detector.get_landmarks(rgb_crop)

    if lm is None:
        return False, None, None, None, None, _cached_bbox

    el = compute_ear(lm, LEFT_EYE_IDX,  cw, ch)
    er = compute_ear(lm, RIGHT_EYE_IDX, cw, ch)
    ea = (el + er) / 2.0
    m  = compute_mar(lm, cw, ch)

    return True, round(el,4), round(er,4), round(ea,4), round(m,4), _cached_bbox


def trim_window(buf, now, window_seconds):
    """Buang entri yang sudah lebih tua dari window_seconds detik dari 'now'.
    Setiap entri buffer diasumsikan tuple yang elemen pertamanya timestamp.
    """
    while buf and (now - buf[0][0]) > window_seconds:
        buf.popleft()


def compute_window_features(now, blink_events_buffer, frame_state_buffer):
    """
    Hitung 3 fitur (Blink Duration, Blink Frequency, PERCLOS) dari sliding
    window WINDOW_SECONDS detik terakhir.

    - Blink Frequency : jumlah kedipan (durasi < MICROSLEEP_EVENT_THRESHOLD)
                        yang selesai dalam window (count, sama seperti skala
                        data training).
    - Blink Duration  : rata-rata durasi kedipan tsb (detik).
    - PERCLOS         : proporsi waktu (0-1) mata tercatat "closed" dalam
                        window, dari total waktu frame yang terekam.
                        CATATAN: ini pendekatan biner (EAR di bawah ambang),
                        bukan literal "kelopak menutup >=80%", karena kode
                        deteksi saat ini hanya punya status open/closed biner.

    Kedua buffer sudah di-trim ke window_seconds sebelum dipanggil.
    """
    blink_frequency = len(blink_events_buffer)
    if blink_frequency > 0:
        blink_duration = sum(d for _, d in blink_events_buffer) / blink_frequency
    else:
        blink_duration = 0.0

    total_dt = sum(dt for _, dt, _ in frame_state_buffer)
    closed_dt = sum(dt for _, dt, closed in frame_state_buffer if closed)
    perclos = (closed_dt / total_dt) if total_dt > 1e-6 else 0.0

    return blink_duration, blink_frequency, perclos


def predict_model(blink_duration, blink_frequency, perclos):
    """Jalankan model XGBoost 3-fitur, kembalikan (label_str, proba_kantuk)."""
    nilai = {
        "Blink Duration": blink_duration,
        "Blink Frequency": blink_frequency,
        "PERCLOS": perclos,
    }
    X = np.array([[nilai[f] for f in MODEL_FEATURES]])
    proba = float(MODEL.predict_proba(X)[0, 1])
    label = int(proba >= MODEL_THRESH)
    return MODEL_LABELS[label], proba


def stage_from_n(n):
    """Peta counter n (0-6) ke stage kantuk.
    n=0 -> S0 | n=1 -> S1 | n=2-3 -> S2 | n=4-6 -> S3
    """
    if n == 0:
        return "S0"
    elif n == 1:
        return "S1"
    elif n <= 3:
        return "S2"
    else:
        return "S3"


