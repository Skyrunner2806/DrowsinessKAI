def send_arduino(code):
    """Kirim 1 karakter kode ke Arduino, hanya kalau berubah dari sebelumnya."""
    global last_code_sent
    code = str(code)
    if code != last_code_sent:
        try:
            arduino.write(code.encode())
            last_code_sent = code
        except Exception as e:
            print(f"[Serial] Error kirim: {e}")


def read_arduino_signals():
    """Baca semua baris yang tersedia dari Arduino, non-blocking.
    Arduino juga mengirim banyak baris log/debug (mis. "[STAGE] ..."), jadi
    hanya baris yang PERSIS 'R' atau 'F' yang dianggap sinyal tombol.
    Mengembalikan list sinyal ('R'/'F') yang ditemukan pada panggilan ini.
    """
    signals = []
    try:
        while arduino.in_waiting > 0:
            raw = arduino.readline().decode(errors="ignore").strip()
            if raw == SIGNAL_RECALIBRATE or raw == SIGNAL_FORCE_STOP:
                signals.append(raw)
            elif raw:
                # Baris log/debug Arduino lain -> tampilkan saja, tidak diproses
                print(f"[Arduino] {raw}")
    except Exception as e:
        print(f"[Serial] Error baca: {e}")
    return signals

