    mlc = (90,90,230) if model_label == "Kantuk" else (60,200,60)
    put(f"Model    : {model_label} (p={model_proba:.2f})", 286, mlc, 0.42, True)
    put(f"Rule bypass: {'AKTIF' if rule_triggered else '-'}", 304,
        (90,90,230) if rule_triggered else (110,110,110), 0.40)
    cv2.line(panel, (8,314), (272,314), (60,60,60), 1)

    fc = (90,90,230) if final_status == "Kantuk" else (60,200,60)
    put("STATUS FINAL:", 334, (140,140,140), 0.42)
    put(final_status.upper(), 356, fc, 0.58, True)

    STAGE_COLORS = {
        "S0": (60,200,60),    # hijau — terjaga
        "S1": (0,190,230),    # kuning/cyan — awal
        "S2": (0,140,255),    # oranye — sedang
        "S3": (60,60,230),    # merah — parah
    }
    stg_col = STAGE_COLORS.get(kantuk_stage, (170,170,170))
    put(f"Stage kantuk : {kantuk_stage}", 378, stg_col, 0.44, True)
    put(f"Counter n    : {n_kantuk} / {N_KANTUK_MAX}", 396, stg_col, 0.38)
    cv2.line(panel, (8,406), (272,406), (60,60,60), 1)

    if is_alert:
        msg = "MICROSLEEP!" if microsleep_sec > MICROSLEEP_LIMIT else "MENGUAP LAMA!"
        cv2.rectangle(panel, (8,416), (272,458), (30,20,140), -1)
        cv2.rectangle(panel, (8,416), (272,458), (90,80,220),  1)
        put("!! ALERT !!",  435, (255,255,255), 0.50, True)
        put(msg,            453, (210,200,255), 0.38)

    return panel

# ═══════════════════════════════════════════════════════════════════════
#  STATE
# ═══════════════════════════════════════════════════════════════════════

phase     = "calibrating"
ear_calib = []
mar_calib = []
t_eye     = None
t_mouth   = None

blinks           = 0
microsleep_sec   = 0.0
yawns            = 0
yawn_duration    = 0.0
eyes_was_closed  = False
yawn_in_progress = False

prev_time = time.time()
no_face_started = None
feature_missing_started = None
face_missing_alert = False
feature_missing_alert = False

# ── Sliding window (60 detik) untuk fitur model & prediksi berjalan ────
blink_events_buffer = deque()   # tiap entri: (timestamp_selesai, durasi)
frame_state_buffer  = deque()   # tiap entri: (timestamp, dt, is_closed)
last_feature_update = 0.0
model_label   = "Terjaga"
model_proba   = 0.0
blink_freq_win = 0
blink_dur_win  = 0.0
perclos_win    = 0.0

log_file = open(LOG_PATH, "a", newline="")
log_writer = csv.writer(log_file)
if log_file.tell() == 0:
    log_writer.writerow([
        "timestamp", "ear_avg", "mar", "eye_state", "mouth_state",
        "blink_freq_window", "blink_duration_window", "perclos_window",
        "model_label", "model_proba", "rule_triggered", "final_status",
        "kantuk_stage", "n_kantuk",
    ])

# ── Tracking stage kantuk (S0-S3) via counter n naik/turun tiap detik ──
last_stage_update = 0.0
n_kantuk    = 0
kantuk_stage = "S0"


def handle_recalibrate():
    """Sinyal 'R' dari tombol D2 -> ulangi kalibrasi kamera dari awal."""
    global phase, ear_calib, mar_calib, t_eye, t_mouth
    phase     = "calibrating"
    ear_calib = []
    mar_calib = []
    t_eye     = None
    t_mouth   = None
    print("[Python] Sinyal 'R' diterima -> mengulang kalibrasi kamera.")


def handle_force_stop():
    """Sinyal 'F' dari tombol D3 -> reset state deteksi & model ke S0,
    TANPA mengulang kalibrasi kamera (kalibrasi tetap terpakai)."""
    global blink_events_buffer, frame_state_buffer
    global n_kantuk, kantuk_stage, model_label, model_proba
    global blink_freq_win, blink_dur_win, perclos_win
    global microsleep_sec, yawn_duration, eyes_was_closed, yawn_in_progress
    global last_feature_update, last_stage_update

    blink_events_buffer.clear()
    frame_state_buffer.clear()
    n_kantuk      = 0
    kantuk_stage  = "S0"
    model_label   = "Terjaga"
    model_proba   = 0.0
    blink_freq_win = 0
    blink_dur_win  = 0.0
    perclos_win    = 0.0
    microsleep_sec   = 0.0
    yawn_duration    = 0.0
    eyes_was_closed  = False
    yawn_in_progress = False
    last_feature_update = 0.0
    last_stage_update   = 0.0
    print("[Python] Sinyal 'F' diterima -> reset state deteksi & model ke S0.")


def metrics_valid(ear_avg, mar):
    """Validasi kasar agar nilai landmark yang tidak masuk akal bisa dianggap fitur tidak terbaca.
    Catatan: MediaPipe tidak selalu memberi confidence per landmark, jadi ini hanya safety check.
    """
    if ear_avg is None or mar is None:
        return False
    if not (0.02 <= ear_avg <= 0.70):
        return False
    if not (0.00 <= mar <= 1.50):
        return False
    return True

# ═══════════════════════════════════════════════════════════════════════
#  MAIN LOOP
# ═══════════════════════════════════════════════════════════════════════

print(f"\nFase kalibrasi: hadapkan wajah ke kamera ({N_CALIB} frame valid).")
print("Tekan Q untuk keluar.\n")

while True:
    ret, frame = cap.read()
    if not ret:
        break

    now       = time.time()
    dt        = now - prev_time
    prev_time = now

    # ── Baca sinyal tombol dari Arduino (non-blocking) ──────────────────
    for sinyal in read_arduino_signals():
        if sinyal == SIGNAL_RECALIBRATE:
            handle_recalibrate()
        elif sinyal == SIGNAL_FORCE_STOP:
            handle_force_stop()

    ih, iw = frame.shape[:2]
    face_ok, el, er, ear_avg, mar, bbox = detect_and_extract(frame, iw, ih)

    # ── FASE KALIBRASI ────────────────────────────────────────────────
    if phase == "calibrating":
        send_arduino(STAGE_TO_CODE["S0"])  # tetap normal selama kalibrasi

        if face_ok:
            ear_calib.append(ear_avg)
            mar_calib.append(mar)

        n_done = len(ear_calib)
        ratio  = n_done / N_CALIB

        ov = frame.copy()
        cv2.rectangle(ov, (0, ih//2-60), (iw, ih//2+65), (20,20,20), -1)
        cv2.addWeighted(ov, 0.75, frame, 0.25, 0, frame)

        cv2.putText(frame, "KALIBRASI — hadapkan wajah ke kamera",
                    (iw//2-195, ih//2-28),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.56, (200,200,200), 1, cv2.LINE_AA)

        bw = iw - 80
        cv2.rectangle(frame, (40, ih//2+2), (40+bw,            ih//2+24), (60,60,60),   -1)
        cv2.rectangle(frame, (40, ih//2+2), (40+int(bw*ratio), ih//2+24), (60,200,60), -1)
        cv2.putText(frame, f"{n_done} / {N_CALIB} frame valid",
                    (iw//2-80, ih//2+48),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.52, (170,170,170), 1, cv2.LINE_AA)

        if not face_ok:
            cv2.putText(frame, "Wajah tidak terdeteksi...",
                        (iw//2-110, ih//2-5),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.48, (80,80,230), 1, cv2.LINE_AA)

        if n_done >= N_CALIB:
            t_eye       = float(np.median(ear_calib)) * EAR_MULT
            t_mouth_raw = float(np.median(mar_calib)) * MAR_MULT
            t_mouth     = max(t_mouth_raw, T_MOUTH_FLOOR)
            phase       = "detecting"
            print("Kalibrasi selesai!")
            print(f"  t_eye   = {t_eye:.4f}")
            print(f"  t_mouth = {t_mouth:.4f}")
            print("Deteksi model + rule aktif.\n")

        cv2.imshow("Drowsiness Detection — Q untuk keluar", frame)
        if cv2.waitKey(1) & 0xFF == ord("q"):
            break
        continue

    # ── FASE DETEKSI ──────────────────────────────────────────────────
    eye_state   = "unknown"
    mouth_state = "unknown"

    # Reset status missing setiap frame, lalu dihitung ulang
    face_missing_alert = False
    feature_missing_alert = False

    rule_triggered = False

    if face_ok and metrics_valid(ear_avg, mar):
        no_face_started = None
        feature_missing_started = None

        eye_state   = "closed"  if ear_avg < t_eye   else "open"
        mouth_state = "yawning" if mar     > t_mouth else "normal"

        if eye_state == "closed":
            if not eyes_was_closed:
                eyes_was_closed = True
                blinks += 1
            microsleep_sec += dt
        else:
            if eyes_was_closed:
                # Mata baru saja terbuka lagi -> satu closure selesai.
                # microsleep_sec saat ini = durasi closure yang baru selesai.
                closure_duration = microsleep_sec
                if closure_duration < MICROSLEEP_EVENT_THRESHOLD:
                    # Kedipan normal -> masuk statistik untuk model
                    blink_events_buffer.append((now, closure_duration))
                # Jika >= threshold, itu microsleep -> sudah ditangani rule,
                # sengaja TIDAK dimasukkan ke statistik blink (konsisten
                # dengan definisi training: blink != microsleep).
            eyes_was_closed = False
            microsleep_sec  = 0.0

        # Catat status frame ini ke buffer window (untuk PERCLOS)
        frame_state_buffer.append((now, dt, eye_state == "closed"))

        if mouth_state == "yawning":
            if not yawn_in_progress:
                yawn_in_progress = True
                yawns += 1
            yawn_duration += dt
        else:
            if yawn_in_progress:
                yawn_in_progress = False
            yawn_duration = 0.0

        # ── Rule bypass: microsleep atau menguap panjang -> langsung Kantuk
        rule_triggered = (microsleep_sec > MICROSLEEP_EVENT_THRESHOLD or
                           yawn_duration  > YAWN_EVENT_THRESHOLD)

        # ── Sliding window: hitung ulang fitur & prediksi tiap 1 detik ──
        trim_window(blink_events_buffer, now, WINDOW_SECONDS)
        trim_window(frame_state_buffer, now, WINDOW_SECONDS)

        if now - last_feature_update >= FEATURE_UPDATE_INTERVAL:
            last_feature_update = now
            blink_dur_win, blink_freq_win, perclos_win = compute_window_features(
                now, blink_events_buffer, frame_state_buffer
            )
            model_label, model_proba = predict_model(
                blink_dur_win, blink_freq_win, perclos_win
            )

        # ── Gabungkan: rule menang jika aktif, kalau tidak pakai model ──
        final_status = "Kantuk" if rule_triggered else model_label

    else:
        eyes_was_closed  = False
        yawn_in_progress = False
        microsleep_sec   = 0.0
        yawn_duration    = 0.0
        final_status     = "Kantuk" if model_label == "Kantuk" else "Terjaga"

        # bbox None  → YOLO tidak melihat wajah sama sekali.
        # bbox ada tetapi face_ok False / metrik tidak valid → wajah ada, tetapi landmark mata/mulut gagal/invalid.
        if bbox is None:
            eye_state   = "no face"
            mouth_state = "no face"
            feature_missing_started = None
            if no_face_started is None:
                no_face_started = now
            face_missing_alert = (now - no_face_started) >= NO_FACE_DELAY
        else:
            eye_state   = "landmark lost"
            mouth_state = "landmark lost"
            no_face_started = None
            if feature_missing_started is None:
                feature_missing_started = now
            feature_missing_alert = (now - feature_missing_started) >= FEATURE_MISSING_DELAY

    # ── Stage kantuk: counter n naik/turun tiap window_second (1 detik) ─
    # berdasarkan final_status gabungan (rule bypass + model) saat itu.
    if now - last_stage_update >= FEATURE_UPDATE_INTERVAL:
        last_stage_update = now
        if final_status == "Kantuk":
            n_kantuk = min(n_kantuk + 1, N_KANTUK_MAX)
        else:
            n_kantuk = max(n_kantuk - 1, N_KANTUK_MIN)
        kantuk_stage = stage_from_n(n_kantuk)

    # ── Kirim ke Arduino: wajah/fitur hilang override stage kantuk ──────
    if face_missing_alert:
        send_arduino(CODE_NO_FACE)
    elif feature_missing_alert:
        send_arduino(CODE_FEATURE_MISSING)
    else:
        send_arduino(STAGE_TO_CODE.get(kantuk_stage, "0"))

    if face_ok and metrics_valid(ear_avg, mar):
        log_writer.writerow([
            f"{now:.3f}", ear_avg, mar, eye_state, mouth_state,
            blink_freq_win, f"{blink_dur_win:.4f}", f"{perclos_win:.5f}",
            model_label, f"{model_proba:.4f}", rule_triggered, final_status,
            kantuk_stage, n_kantuk,
        ])

    is_alert = (microsleep_sec > MICROSLEEP_LIMIT or
                yawn_duration  > YAWN_LIMIT or
                face_missing_alert or
                feature_missing_alert or
                final_status == "Kantuk")

    if bbox:
        x1, y1, x2, y2 = bbox
        bc = (0,0,220) if is_alert else (60,200,60)
        cv2.rectangle(frame, (x1,y1), (x2,y2), bc, 2)
        if ear_avg is not None:
            ec = (90,90,230) if eye_state == "closed" else (60,200,60)
            cv2.putText(frame, f"EAR:{ear_avg:.3f}  MAR:{mar:.3f}",
                        (x1, max(y1-7, 12)),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.38, ec, 1, cv2.LINE_AA)

    if is_alert:
        ov = frame.copy()
        cv2.rectangle(ov, (0,0), (iw,46), (0,0,150), -1)
        cv2.addWeighted(ov, 0.65, frame, 0.35, 0, frame)
        if face_missing_alert:
            msg = "!! WAJAH TIDAK TERDETEKSI !!"
        elif feature_missing_alert:
            msg = "!! MATA/MULUT TIDAK TERDETEKSI !!"
        elif microsleep_sec > MICROSLEEP_LIMIT:
            msg = f"!! MICROSLEEP ALERT ({kantuk_stage}) !!"
        elif yawn_duration > YAWN_LIMIT:
            msg = f"!! YAWN ALERT ({kantuk_stage}) !!"
        else:
            msg = f"!! KANTUK TERDETEKSI ({kantuk_stage}) !!"
        cv2.putText(frame, msg, (10,32),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.82, (255,255,255), 2, cv2.LINE_AA)

    panel   = draw_panel(ih, ear_avg, mar, eye_state, mouth_state, is_alert,
                          model_label, model_proba, final_status, rule_triggered,
                          blink_freq_win, blink_dur_win, perclos_win,
                          kantuk_stage, n_kantuk)
    display = np.hstack([frame, panel])
    cv2.imshow("Drowsiness Detection — Q untuk keluar", display)

    if cv2.waitKey(1) & 0xFF == ord("q"):
        break

# ── Cleanup ───────────────────────────────────────────────────────────
send_arduino(STAGE_TO_CODE["S0"])
cap.release()
cv2.destroyAllWindows()
face_detector.close()
log_file.close()
arduino.close()
print(f"Log tersimpan di {LOG_PATH}")
print("Selesai.")
